#!/usr/bin/env bash
# easy-opal — self-bootstrapping entry point
# Clone the repo, run ./easy-opal — it handles everything.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Ensure uv is available ───────────────────────────────────────────────────
ensure_uv() {
    if command -v uv &>/dev/null; then
        return
    fi

    # Check common install locations not yet in PATH
    for p in "$HOME/.local/bin/uv" "$HOME/.cargo/bin/uv" "/usr/local/bin/uv"; do
        if [ -x "$p" ]; then
            export PATH="$(dirname "$p"):$PATH"
            return
        fi
    done

    # Install uv
    echo "Installing uv (Python package manager)..."
    if command -v curl &>/dev/null; then
        curl -LsSf https://astral.sh/uv/install.sh | sh
    elif command -v wget &>/dev/null; then
        wget -qO- https://astral.sh/uv/install.sh | sh
    else
        echo "Error: curl or wget is required to install uv." >&2
        echo "Install one of them and try again." >&2
        exit 1
    fi
    export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

    if ! command -v uv &>/dev/null; then
        echo "Error: uv installation failed." >&2
        echo "Try installing manually: https://docs.astral.sh/uv/getting-started/installation/" >&2
        exit 1
    fi
    echo "uv installed successfully."
}

ensure_uv

# ── Delegate to uv run ───────────────────────────────────────────────────────
# uv run automatically:
#   1. Installs the Python version from .python-version if missing
#   2. Creates .venv if missing
#   3. Syncs dependencies from pyproject.toml if needed
#   4. Executes the command inside the venv
exec uv run --project "$SCRIPT_DIR" python -m src.cli "$@"
